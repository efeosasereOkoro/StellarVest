# Copy to .env.local and fill in real values. Do NOT put real secrets in this file.

# Neon Postgres connection strings.
# DATABASE_URL = pooled host (…-pooler.…) — used by the app at runtime.
# DIRECT_URL   = direct host (no -pooler) — used for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Neon Auth (powered by Better Auth) — from the Neon console → Auth → Configuration.
# Both are public endpoints (not secret).
NEXT_PUBLIC_NEON_AUTH_URL="https://<project>.neonauth.<region>.aws.neon.tech/neondb/auth"
NEON_AUTH_JWKS_URL="https://<project>.neonauth.<region>.aws.neon.tech/neondb/auth/.well-known/jwks.json"

# Admin allowlist — emails granted admin access (comma-separated, server-side only).
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# Slack incoming webhook for the admin channel (B-063) — every admin
# notification (new KYC, pledges, payment reported, founder submissions,
# updates to moderate, deals awaiting committee) is mirrored there.
# Create: Slack → Apps → Incoming Webhooks → pick the channel. SECRET — keep
# out of git/chat. Unset = Slack mirroring off (everything else still works).
SLACK_WEBHOOK_URL=""
