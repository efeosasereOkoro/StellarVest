# Copy to .env.local and fill in real values. Do NOT put real secrets in this file.

# Neon Postgres connection strings.
# DATABASE_URL = pooled host (…-pooler.…) — used by the app at runtime.
# DIRECT_URL   = direct host (no -pooler) — used for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Neon Auth (Stack Auth) — from the Neon console → Auth tab.
# The first two are public (sent to the browser); the server key is secret.
NEXT_PUBLIC_STACK_PROJECT_ID=""
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=""
STACK_SECRET_SERVER_KEY=""
